{
  "compilerOptions": {
    /* Core Setup */
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./dist",

    /* Strictness */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,

    /* Module Handling */
    "esModuleInterop": true,
    "moduleResolution": "node",

    /* Types */
    "types": ["node"],

    /* Output */
    "sourceMap": true,

    /* Performance */
    "skipLibCheck": true,

    "ignoreDeprecations": "6.0"

  },
  "include": ["src"],
  "exclude": ["node_modules"]
}